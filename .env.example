# Copy this file to .env.local and fill in the values.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: a SQLite file managed by better-sqlite3. No Docker, no daemon.
# Cloudflare deploy: D1 binding declared in wrangler.toml — this variable is
# ignored at runtime when the D1 binding is present.
DATABASE_URL="file:./dev.db"

# ── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate with `openssl rand -base64 32`. Required in all environments.
AUTH_SECRET=""

# Trust the host header in production behind a proxy. Set to true on Cloudflare Pages.
# AUTH_TRUST_HOST="true"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Optional in development if you use the dev login below.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Development login (NODE_ENV !== production only) ─────────────────────────
# Lets you bypass Google by typing any work email on /login. ON by default
# in dev; set to "false" to hide the form. Hard-blocked in production
# regardless of this value.
# ENABLE_DEV_LOGIN="true"

# ── Integrations encryption (Phase 2) ────────────────────────────────────────
# AES-GCM key used to encrypt Stripe / HubSpot credentials at rest. Generate
# with `openssl rand -base64 32`. Rotate by re-encrypting integrations.* rows.
INTEGRATIONS_KMS_KEY=""
